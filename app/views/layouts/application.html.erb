<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <title><%= content_for(:title) || "The Chronicler" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="The Chronicler">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-background text-on-background font-body min-h-screen selection:bg-primary/30">

    <%# Flash messages %>
    <% if notice %>
      <div id="flash-notice" class="fixed top-4 right-4 z-[100] bg-surface-container-high border border-primary/30 text-on-surface px-6 py-3 rounded-lg shadow-lg text-sm font-medium" data-controller="flash">
        <span class="material-symbols-outlined text-primary text-sm align-middle mr-1">check_circle</span>
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div id="flash-alert" class="fixed top-4 right-4 z-[100] bg-error-container border border-error/30 text-error px-6 py-3 rounded-lg shadow-lg text-sm font-medium" data-controller="flash">
        <span class="material-symbols-outlined text-sm align-middle mr-1">warning</span>
        <%= alert %>
      </div>
    <% end %>

    <% if authenticated? %>
      <%# ── Top navigation bar ── %>
      <header class="flex justify-between items-center px-8 h-16 w-full fixed top-0 z-50 bg-[#121416]/80 backdrop-blur-xl bg-gradient-to-b from-[#333537]/10 to-transparent shadow-[0_40px_60px_-15px_rgba(226,226,229,0.06)]">
        <div class="flex items-center gap-8">
          <%= link_to campaigns_path, class: "text-2xl font-bold text-primary tracking-[0.02em] font-headline" do %>
            The Chronicler
          <% end %>

          <nav class="hidden md:flex gap-6 items-center">
            <%= link_to "Lobby", campaigns_path,
                  class: "transition-all duration-300 font-medium text-sm #{current_page?(campaigns_path) ? 'text-primary border-b-2 border-primary pb-1' : 'text-on-surface opacity-70 hover:text-primary hover:opacity-100'}" %>
            <% if Current.campaign %>
              <%= link_to "Campaign", campaign_path(Current.campaign),
                    class: "transition-all duration-300 font-medium text-sm #{current_page?(campaign_path(Current.campaign)) ? 'text-primary border-b-2 border-primary pb-1' : 'text-on-surface opacity-70 hover:text-primary hover:opacity-100'}" %>
            <% end %>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <button class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">notifications</button>
          <button class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">history_edu</button>
          <%= button_to session_path, method: :delete, class: "material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors bg-transparent border-0 cursor-pointer" do %>
            account_circle
          <% end %>
        </div>
      </header>

      <%# ── Left sidebar ── %>
      <aside class="hidden md:flex flex-col h-screen pt-20 pb-6 w-64 fixed left-0 top-0 bg-surface-container-low border-r border-outline-variant/15 shadow-[inset_-10px_0_20px_-10px_rgba(0,0,0,0.5)] z-40">
        <div class="px-6 mb-8">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center text-primary border border-outline-variant/20">
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">castle</span>
            </div>
            <div>
              <p class="text-primary font-headline text-base leading-tight">The Chronicler</p>
              <p class="text-[10px] text-on-surface-variant/60 font-medium tracking-wider uppercase">Master of the Realm</p>
            </div>
          </div>
        </div>

        <nav class="flex-1 space-y-1 pr-4">
          <%= link_to campaigns_path,
                class: "flex items-center gap-3 px-6 py-3 text-sm font-medium transition-all duration-300 #{current_page?(campaigns_path) ? 'nav-active' : 'text-on-surface opacity-70 hover:bg-surface-container-highest/50 hover:opacity-100 hover:translate-x-1'}" do %>
            <span class="material-symbols-outlined">castle</span>
            <span>Lobby</span>
          <% end %>

          <% if Current.campaign %>
            <% character = Current.membership&.character %>
            <% if character %>
              <%= link_to character_sheet_path(character),
                    class: "flex items-center gap-3 px-6 py-3 text-sm font-medium transition-all duration-300 #{current_page?(character_sheet_path(character)) ? 'nav-active' : 'text-on-surface opacity-70 hover:bg-surface-container-highest/50 hover:opacity-100 hover:translate-x-1'}" do %>
                <span class="material-symbols-outlined">person_book</span>
                <span>Character Sheet</span>
              <% end %>

              <%= link_to character_inventory_items_path(character),
                    class: "flex items-center gap-3 px-6 py-3 text-sm font-medium transition-all duration-300 #{current_page?(character_inventory_items_path(character)) ? 'nav-active' : 'text-on-surface opacity-70 hover:bg-surface-container-highest/50 hover:opacity-100 hover:translate-x-1'}" do %>
                <span class="material-symbols-outlined">auto_stories</span>
                <span>Inventory &amp; Spells</span>
              <% end %>
            <% end %>

            <% if Current.membership&.game_master? %>
              <%= link_to campaign_path(Current.campaign),
                    class: "flex items-center gap-3 px-6 py-3 text-sm font-medium transition-all duration-300 #{current_page?(campaign_path(Current.campaign)) ? 'nav-active' : 'text-on-surface opacity-70 hover:bg-surface-container-highest/50 hover:opacity-100 hover:translate-x-1'}" do %>
                <span class="material-symbols-outlined">gavel</span>
                <span>GM Manager</span>
              <% end %>
            <% end %>
          <% end %>
        </nav>

        <div class="px-4 mt-auto space-y-4">
          <% if Current.campaign %>
            <% latest_session = Current.campaign.game_sessions.planned.order(created_at: :desc).first %>
            <% if latest_session %>
              <%= link_to campaign_game_session_path(Current.campaign, latest_session),
                    class: "w-full py-3 btn-primary rounded-lg flex items-center justify-center gap-2 text-sm" do %>
                <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1">swords</span>
                Launch Session
              <% end %>
            <% end %>
          <% end %>

          <div class="space-y-1 pt-4 border-t border-outline-variant/20">
            <a href="#" class="flex items-center gap-3 px-2 py-2 text-on-surface opacity-60 hover:opacity-100 transition-opacity text-xs">
              <span class="material-symbols-outlined text-xl">settings</span>
              <span class="uppercase tracking-widest font-bold">Settings</span>
            </a>
          </div>
        </div>
      </aside>

      <%# ── Main content ── %>
      <main class="md:ml-64 pt-24 px-6 pb-12 min-h-screen">
        <%= yield %>
      </main>

    <% else %>
      <%# Unauthenticated — full-screen centered layout %>
      <main class="min-h-screen flex items-center justify-center px-4">
        <%= yield %>
      </main>
    <% end %>

  </body>
</html>
