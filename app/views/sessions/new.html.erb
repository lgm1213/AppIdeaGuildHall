<%= content_for :title, "Sign In — The Chronicler" %>

<div class="w-full max-w-md">
  <div class="text-center mb-10">
    <div class="w-16 h-16 rounded-2xl bg-surface-container-highest border border-outline-variant/20 flex items-center justify-center mx-auto mb-6">
      <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings:'FILL' 1">castle</span>
    </div>
    <h1 class="font-headline text-4xl font-bold text-primary tracking-tight mb-2">The Chronicler</h1>
    <p class="text-on-surface-variant text-sm">Master of the Realm awaits your return</p>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/15 rounded-xl p-8 shadow-2xl">
    <%= form_with url: session_path, class: "space-y-5" do |f| %>
      <div>
        <label class="stat-label block mb-2">Email Address</label>
        <%= f.email_field :email_address,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "you@example.com",
              autocomplete: "email",
              autofocus: true %>
      </div>

      <div>
        <label class="stat-label block mb-2">Password</label>
        <%= f.password_field :password,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "••••••••",
              autocomplete: "current-password" %>
      </div>

      <%= f.submit "Enter the Realm",
            class: "btn-primary w-full py-3 rounded-lg cursor-pointer text-base mt-2" %>
    <% end %>

    <div class="mt-6 pt-6 border-t border-outline-variant/15 flex items-center justify-between text-sm">
      <%= link_to "Forgot password?", new_password_path,
            class: "text-on-surface-variant hover:text-primary transition-colors" %>
      <%= link_to "Create account", new_registration_path,
            class: "text-primary hover:underline font-bold" %>
    </div>
  </div>
</div>
