<%= content_for :title, "Reset Password — The Chronicler" %>

<div class="w-full max-w-md">
  <div class="text-center mb-10">
    <div class="w-16 h-16 rounded-2xl bg-surface-container-highest border border-outline-variant/20 flex items-center justify-center mx-auto mb-6">
      <span class="material-symbols-outlined text-primary text-3xl">lock_reset</span>
    </div>
    <h1 class="font-headline text-3xl font-bold text-on-surface tracking-tight mb-2">Forgot Password?</h1>
    <p class="text-on-surface-variant text-sm">Enter your email and we'll send a reset link</p>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/15 rounded-xl p-8 shadow-2xl">
    <%= form_with url: passwords_path, class: "space-y-5" do |f| %>
      <div>
        <label class="stat-label block mb-2">Email Address</label>
        <%= f.email_field :email_address,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "you@example.com",
              autocomplete: "email",
              autofocus: true %>
      </div>

      <%= f.submit "Send Reset Link",
            class: "btn-primary w-full py-3 rounded-lg cursor-pointer" %>
    <% end %>

    <div class="mt-6 text-center text-sm">
      <%= link_to "Back to sign in", new_session_path,
            class: "text-primary hover:underline font-bold" %>
    </div>
  </div>
</div>
