<%= content_for :title, "Edit Encounter — #{@encounter.name} — The Chronicler" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1"><%= @campaign.name %> · <%= @game_session.title %></p>
    <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight mb-2">Edit Encounter</h1>
  </div>

  <%= render "form", encounter: @encounter, campaign: @campaign, game_session: @game_session %>
</div>
