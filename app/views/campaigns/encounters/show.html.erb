<%= content_for :title, "#{@encounter.name} — The Chronicler" %>
<%= turbo_stream_from @encounter %>

<div class="max-w-5xl mx-auto">
  <div class="mb-8 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1">
        <%= @campaign.name %> · <%= @game_session.title %>
      </p>
      <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight mb-2"><%= @encounter.name %></h1>
      <span class="text-xs border rounded px-2 py-0.5 capitalize
        <%= @encounter.active? ? 'border-primary/30 text-primary' : 'border-outline/30 text-outline' %>">
        <%= @encounter.status %>
      </span>
      <% if @encounter.description.present? %>
        <p class="text-on-surface-variant text-sm mt-3"><%= @encounter.description %></p>
      <% end %>
    </div>
    <% if Current.membership&.game_master? %>
      <div class="flex gap-2 shrink-0 flex-wrap">
        <% if @encounter.pending? && @participants.any? %>
          <%= button_to encounter_initiative_roll_path(@encounter),
                method: :post,
                data: { turbo_confirm: "Roll initiative for all #{@participants.size} participants?" },
                class: "btn-primary px-4 py-2 rounded-lg flex items-center gap-1 text-sm cursor-pointer" do %>
            <span class="material-symbols-outlined text-sm">casino</span>
            Roll Initiative
          <% end %>
        <% end %>
        <%= link_to edit_encounter_path(@encounter),
              class: "btn-secondary px-4 py-2 rounded-lg flex items-center gap-1 text-sm" do %>
          <span class="material-symbols-outlined text-sm">edit</span>
          Edit
        <% end %>
        <%= button_to encounter_path(@encounter),
              method: :delete,
              data: { turbo_confirm: "Delete #{@encounter.name}?" },
              class: "btn-secondary px-4 py-2 rounded-lg flex items-center gap-1 text-sm text-error border-error/30 hover:bg-error/10 cursor-pointer" do %>
          <span class="material-symbols-outlined text-sm">delete</span>
          Delete
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "participants_panel",
        encounter:            @encounter,
        participants:         @participants,
        available_characters: @available_characters,
        campaign_enemies:     @campaign_enemies %>

  <% if @encounter.active? %>
    <%= render "action_panel",
          encounter:           @encounter,
          current_participant: @current_participant,
          participants:        @participants,
          can_act:             @can_act %>
  <% end %>
</div>
