<%= content_for :title, "Edit #{@game_session.title} — The Chronicler" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1"><%= @campaign.name %></p>
    <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight mb-2">Edit Session</h1>
    <p class="text-on-surface-variant"><%= @game_session.title %></p>
  </div>

  <%= render "form", game_session: @game_session, campaign: @campaign %>
</div>
