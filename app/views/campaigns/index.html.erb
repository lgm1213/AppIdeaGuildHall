<%= content_for :title, "Campaign Lobby — The Chronicler" %>

<div class="max-w-7xl mx-auto">
  <%# Header & actions %>
  <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-12">
    <div class="flex-1">
      <h1 class="font-headline text-5xl font-bold text-primary tracking-tight mb-2">Campaign Lobby</h1>
      <p class="text-on-surface-variant max-w-xl text-lg">Continue your journey through the shattered realms or forge a new destiny with your companions.</p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
      <%= form_with url: invitation_redemptions_path, method: :post,
            class: "relative group flex-1 sm:w-80 flex" do |f| %>
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-secondary transition-colors pointer-events-none">add_link</span>
        <%= f.text_field :invitation_redemption_code,
              name: "invitation_redemption[code]",
              class: "w-full bg-surface-container-low border border-outline-variant/30 rounded-l-lg py-3 pl-12 pr-4 focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary text-on-surface transition-all tracking-widest uppercase placeholder:normal-case placeholder:tracking-normal",
              placeholder: "Enter invite code…",
              maxlength: 8,
              autocomplete: "off" %>
        <%= f.submit "Join",
              class: "bg-secondary text-on-secondary font-bold px-5 rounded-r-lg cursor-pointer hover:brightness-110 transition-all shrink-0" %>
      <% end %>
      <%= link_to new_campaign_path,
            class: "btn-primary px-6 py-3 rounded-lg flex items-center justify-center gap-2 whitespace-nowrap" do %>
        <span class="material-symbols-outlined">add_circle</span>
        Create New Campaign
      <% end %>
    </div>
  </div>

  <%# Campaign grid %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    <% @campaigns.each do |campaign| %>
      <% membership = campaign.campaign_memberships.find { |m| m.user_id == Current.user.id } %>
      <% is_gm    = membership&.game_master? %>
      <% character = membership&.character %>

      <div class="relative group bg-surface-container-low rounded-xl overflow-hidden shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-outline-variant/10">
        <div class="absolute inset-0 grainy-surface pointer-events-none"></div>

        <%# Campaign banner %>
        <div class="h-32 w-full relative bg-gradient-to-br from-surface-container-high to-surface-container-highest flex items-center justify-center">
          <span class="material-symbols-outlined text-5xl text-outline/20" style="font-variation-settings:'FILL' 1">castle</span>
          <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low via-transparent to-transparent"></div>

          <%# Role badge %>
          <% if is_gm %>
            <div class="absolute top-4 right-4 bg-primary/20 backdrop-blur-md border border-primary/30 text-primary px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase">
              Game Master
            </div>
          <% else %>
            <div class="absolute top-4 right-4 bg-secondary/20 backdrop-blur-md border border-secondary/30 text-secondary px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase">
              Player
            </div>
          <% end %>
        </div>

        <div class="p-6">
          <h3 class="font-headline text-2xl font-bold text-on-surface mb-1"><%= campaign.name %></h3>
          <p class="text-sm text-on-surface-variant/80 font-medium mb-4">
            <%= campaign.game_system&.name || "No system" %> &bull;
            <span class="capitalize"><%= campaign.status %></span>
          </p>

          <%# Character preview for players %>
          <% if !is_gm && character %>
            <div class="bg-surface-container-highest/50 rounded-lg p-3 flex items-center gap-4 mb-6 border border-outline-variant/10">
              <% if character.avatar.attached? %>
                <%= image_tag character.avatar, class: "w-12 h-12 rounded-lg object-cover border border-primary/30" %>
              <% else %>
                <div class="w-12 h-12 rounded-lg bg-surface-container border border-primary/30 flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary">person</span>
                </div>
              <% end %>

              <div class="flex-1 min-w-0">
                <div class="flex justify-between items-center gap-2">
                  <p class="font-bold text-primary leading-tight truncate"><%= character.name %></p>
                  <span class="text-[10px] font-black text-secondary uppercase bg-secondary/10 px-1.5 py-0.5 rounded shrink-0">LVL <%= character.total_level %></span>
                </div>
                <p class="text-xs text-on-surface-variant/70 italic truncate">
                  <%= character.character_classes.map(&:name).join(" / ").presence || character.race %>
                </p>
              </div>
            </div>
          <% elsif is_gm && !character %>
            <%# Spacer for consistent card height %>
            <div class="mb-6"></div>
          <% end %>

          <div class="flex items-center justify-between pt-4 border-t border-outline-variant/10">
            <% if is_gm %>
              <%# Member avatars %>
              <div class="flex -space-x-2">
                <% campaign.campaign_memberships.first(4).each do %>
                  <div class="w-8 h-8 rounded-full border-2 border-surface-container-low bg-surface-container-highest flex items-center justify-center">
                    <span class="material-symbols-outlined text-sm text-on-surface-variant">person</span>
                  </div>
                <% end %>
              </div>
              <%= link_to campaign_path(campaign),
                    class: "text-secondary hover:text-primary transition-colors flex items-center gap-1 font-bold text-sm uppercase tracking-wider" do %>
                Manage Realm
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              <% end %>
            <% else %>
              <div></div>
              <%= link_to campaign_path(campaign),
                    class: "bg-surface-container-highest text-primary font-bold px-4 py-2 rounded border border-primary/20 hover:bg-primary hover:text-on-primary transition-all text-sm uppercase tracking-wider" do %>
                Enter Game
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# New campaign empty-state card %>
    <%= link_to new_campaign_path,
          class: "group border-2 border-dashed border-outline-variant/20 rounded-xl flex flex-col items-center justify-center p-12 text-center hover:border-primary/40 hover:bg-primary/5 transition-all min-h-[360px]" do %>
      <div class="w-16 h-16 rounded-full bg-surface-container-highest flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-primary text-3xl">add</span>
      </div>
      <h4 class="font-headline text-xl font-bold text-on-surface mb-2">Start a New Journey</h4>
      <p class="text-sm text-on-surface-variant max-w-[200px]">Gather your party and begin a new campaign as a Game Master.</p>
    <% end %>
  </div>

  <%# Realm Tidings — editorial section %>
  <section class="mt-20">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="font-headline text-3xl font-bold text-on-surface">Realm Tidings</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-outline-variant/30 to-transparent"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="relative bg-surface-container-high rounded-xl overflow-hidden flex flex-col md:flex-row shadow-xl border border-outline-variant/10">
        <div class="md:w-2/5 bg-surface-container-highest h-40 md:h-auto flex items-center justify-center">
          <span class="material-symbols-outlined text-6xl text-outline/20" style="font-variation-settings:'FILL' 1">castle</span>
        </div>
        <div class="p-8 md:w-3/5 flex flex-col justify-center">
          <span class="text-xs font-black text-secondary tracking-widest uppercase mb-2">New Module</span>
          <h3 class="font-headline text-2xl font-bold text-on-surface mb-4 leading-tight">The Whispering Cathedral</h3>
          <p class="text-sm text-on-surface-variant mb-6 line-clamp-3">A gothic horror adventure designed for levels 5-8. Discover the dark secrets buried beneath the silent stones of Saint Valery's…</p>
          <a href="#" class="text-primary font-bold text-sm uppercase tracking-wider hover:underline">Explore Module</a>
        </div>
      </div>

      <div class="space-y-4">
        <div class="bg-surface-container-low p-4 rounded-lg border-l-4 border-primary flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1">update</span>
          </div>
          <div>
            <h4 class="font-bold text-on-surface">The Chronicler v1.0</h4>
            <p class="text-xs text-on-surface-variant">Character sheets, inventory, and spellbook management now live.</p>
          </div>
        </div>

        <div class="bg-surface-container-low p-4 rounded-lg border-l-4 border-secondary flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1">swords</span>
          </div>
          <div>
            <h4 class="font-bold text-on-surface">Combat Tracker</h4>
            <p class="text-xs text-on-surface-variant">Full round-by-round encounter tracking with initiative order is ready.</p>
          </div>
        </div>

        <div class="bg-surface-container-low p-4 rounded-lg border-l-4 border-tertiary flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-tertiary" style="font-variation-settings:'FILL' 1">groups</span>
          </div>
          <div>
            <h4 class="font-bold text-on-surface">Multi-System Support</h4>
            <p class="text-xs text-on-surface-variant">D&amp;D 5e is live. Pathfinder and Call of Cthulhu coming soon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
