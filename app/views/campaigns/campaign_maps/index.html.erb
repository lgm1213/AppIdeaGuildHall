<%= content_for :title, "Maps — #{@campaign.name} — The Chronicler" %>

<div class="flex items-center justify-between mb-8">
  <div>
    <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1"><%= @campaign.name %></p>
    <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight">Maps</h1>
  </div>
  <%= link_to new_campaign_campaign_map_path(@campaign),
        class: "btn-primary px-5 py-2.5 rounded-lg flex items-center gap-2 text-sm" do %>
    <span class="material-symbols-outlined text-sm">add</span>
    New Map
  <% end %>
</div>

<% if @campaign_maps.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    <% @campaign_maps.each do |map| %>
      <%= link_to campaign_campaign_map_path(@campaign, map),
            class: "card overflow-hidden hover:border-primary/30 transition-all group" do %>
        <% if map.image.attached? %>
          <%= image_tag map.image, class: "w-full h-40 object-cover" %>
        <% else %>
          <div class="w-full h-40 bg-surface-container flex items-center justify-center">
            <span class="material-symbols-outlined text-4xl text-primary/30">map</span>
          </div>
        <% end %>
        <div class="p-4">
          <h3 class="font-bold text-on-surface group-hover:text-primary transition-colors mb-1"><%= map.name %></h3>
          <span class="stat-label capitalize"><%= map.map_type %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card p-12 text-center">
    <span class="material-symbols-outlined text-4xl text-primary/40 mb-3">map</span>
    <p class="text-on-surface-variant">No maps yet. Add one to chart your world.</p>
    <%= link_to "Add Map", new_campaign_campaign_map_path(@campaign), class: "btn-primary px-6 py-2.5 rounded-lg inline-block mt-4 text-sm" %>
  </div>
<% end %>
