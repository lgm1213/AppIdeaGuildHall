<%= content_for :title, "Add Item — #{@character.name} — The Chronicler" %>

<div class="max-w-xl mx-auto">
  <div class="mb-8">
    <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1"><%= @character.name %></p>
    <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight mb-2">Add Item</h1>
  </div>

  <div class="card p-8">
    <%= form_with model: [@character, @item], url: character_inventory_items_path(@character) do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :name, "Item Name", class: "stat-label mb-2 block" %>
          <%= f.text_field :name, class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all", placeholder: "e.g. Longsword +1", autofocus: true %>
        </div>

        <div class="grid grid-cols-2 gap-5" data-controller="weapon-stats">
          <div>
            <%= f.label :item_type, "Type", class: "stat-label mb-2 block" %>
            <%= f.select :item_type,
                  InventoryItem.item_types.keys.map { |t| [t.capitalize, t] },
                  {},
                  class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
                  data: { weapon_stats_target: "typeSelect", action: "change->weapon-stats#toggle" } %>
          </div>

          <div>
            <%= f.label :quantity, "Quantity", class: "stat-label mb-2 block" %>
            <%= f.number_field :quantity, min: 0, value: 1, class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" %>
          </div>
        </div>

        <div>
          <%= f.label :weight, "Weight (lbs)", class: "stat-label mb-2 block" %>
          <%= f.number_field :weight, min: 0, step: 0.1, value: 0, class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" %>
        </div>

        <div>
          <%= f.label :description, "Description", class: "stat-label mb-2 block" %>
          <%= f.text_area :description, rows: 3, class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all resize-none", placeholder: "Notes, properties, attunement…" %>
        </div>

        <%# ── Weapon stats (shown when type = weapon) ──────────────── %>
        <div data-weapon-stats-target="weaponSection" class="hidden border border-outline-variant/20 rounded-lg p-4 bg-surface-container-low space-y-4">
          <p class="stat-label">
            <span class="material-symbols-outlined text-sm align-middle mr-0.5">swords</span>
            Weapon Stats
          </p>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :damage_dice, "Damage Dice", class: "stat-label mb-2 block" %>
              <%= f.text_field :damage_dice, placeholder: "e.g. 1d8",
                    class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
            </div>
            <div>
              <%= f.label :damage_type, "Damage Type", class: "stat-label mb-2 block" %>
              <%= f.text_field :damage_type, placeholder: "e.g. slashing",
                    class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <%= f.label :attack_stat, "Attack Stat", class: "stat-label mb-2 block" %>
              <%= f.select :attack_stat,
                    [ [ "STR", "strength" ], [ "DEX", "dexterity" ], [ "None", "" ] ],
                    { include_blank: "— stat —" },
                    class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
            </div>
            <div>
              <%= f.label :attack_bonus, "Atk Bonus", class: "stat-label mb-2 block" %>
              <%= f.number_field :attack_bonus,
                    class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
            </div>
            <div>
              <%= f.label :damage_bonus, "Dmg Bonus", class: "stat-label mb-2 block" %>
              <%= f.number_field :damage_bonus,
                    class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
            </div>
          </div>

          <div class="w-1/3">
            <%= f.label :reach, "Reach (ft)", class: "stat-label mb-2 block" %>
            <%= f.number_field :reach, min: 5, step: 5,
                  class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg px-3 py-2 text-on-surface text-sm focus:outline-none focus:border-primary transition-all" %>
          </div>
        </div>

        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :equipped, class: "w-4 h-4 accent-primary" %>
          <span class="text-sm text-on-surface-variant">Equipped</span>
        </label>

        <div class="flex gap-3 pt-2">
          <%= f.submit "Add Item", class: "btn-primary px-8 py-2.5 rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", character_inventory_items_path(@character), class: "btn-secondary px-6 py-2.5 rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
