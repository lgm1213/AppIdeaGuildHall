<%# locals: (character_spell:, character:) %>
<div id="<%= dom_id(character_spell) %>"
     class="p-4 bg-surface-container-highest rounded-xl border-l-4 <%= character_spell.cantrip? ? "border-secondary/50" : "border-secondary" %> group hover:bg-surface-bright transition-colors">
  <div class="flex justify-between items-start mb-2">
    <div class="flex items-center gap-2 flex-1 min-w-0">
      <h4 class="font-bold text-on-surface group-hover:text-secondary transition-colors truncate"><%= character_spell.name %></h4>
      <% if character_spell.school.present? %>
        <span class="text-[10px] bg-secondary/10 text-secondary px-2 py-0.5 rounded shrink-0"><%= character_spell.school %></span>
      <% end %>
      <% if character_spell.concentration? %>
        <span class="text-[9px] border border-secondary/30 text-secondary/70 px-1.5 py-0.5 rounded shrink-0">C</span>
      <% end %>
      <% if character_spell.ritual? %>
        <span class="text-[9px] border border-outline-variant/40 text-outline px-1.5 py-0.5 rounded shrink-0">R</span>
      <% end %>
    </div>
    <%= button_to character_character_spell_path(character, character_spell),
          method: :delete,
          data: { turbo_confirm: "Remove #{character_spell.name}?" },
          class: "text-outline hover:text-error transition-colors bg-transparent border-0 cursor-pointer p-0 shrink-0 ml-2 opacity-0 group-hover:opacity-100" do %>
      <span class="material-symbols-outlined text-sm">delete</span>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-x-4 gap-y-1 text-[10px] text-on-surface-variant">
    <% if character_spell.casting_time.present? %>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-[12px]">schedule</span>
        <%= character_spell.casting_time %>
      </div>
    <% end %>
    <% if character_spell.range.present? %>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-[12px]">ads_click</span>
        <%= character_spell.range %>
      </div>
    <% end %>
    <% if character_spell.duration.present? %>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-[12px]">timer</span>
        <%= character_spell.duration %>
      </div>
    <% end %>
    <% if character_spell.components.present? %>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-[12px]">category</span>
        <%= character_spell.components %>
      </div>
    <% end %>
  </div>

  <% if character_spell.description.present? %>
    <p class="mt-2 text-xs text-on-surface-variant leading-relaxed line-clamp-2"><%= character_spell.description %></p>
  <% end %>
</div>
