<%= content_for :title, "#{@character.name} — The Chronicler" %>

<%# ── Character Hero Header ────────────────────────────────────────────────── %>
<section class="relative mb-10 overflow-hidden rounded-xl bg-surface-container-low border border-outline-variant/10">
  <div class="absolute inset-0 bg-gradient-to-r from-background via-background/70 to-transparent"></div>

  <div class="relative z-10 p-8 flex flex-col md:flex-row items-center gap-8">
    <div class="relative group shrink-0">
      <div class="absolute -inset-1 bg-primary/20 blur rounded-full group-hover:bg-primary/40 transition duration-700"></div>
      <% if @character.avatar.attached? %>
        <%= image_tag @character.avatar,
              class: "relative w-36 h-36 md:w-48 md:h-48 object-cover rounded-full border-4 border-primary/30 shadow-2xl" %>
      <% else %>
        <div class="relative w-36 h-36 md:w-48 md:h-48 rounded-full border-4 border-primary/30 bg-surface-container-highest flex items-center justify-center">
          <span class="material-symbols-outlined text-6xl text-primary/40">person</span>
        </div>
      <% end %>
    </div>

    <div class="text-center md:text-left">
      <h1 class="text-4xl md:text-6xl font-headline font-bold text-on-background tracking-tight mb-3">
        <%= @character.name %>
      </h1>
      <div class="flex flex-wrap justify-center md:justify-start gap-3">
        <% @classes.each do |cls| %>
          <span class="bg-primary/10 text-primary border border-primary/20 px-4 py-1 rounded-full text-sm font-bold uppercase tracking-widest">
            Level <%= cls.level %> <%= cls.name %><%= " (#{cls.subclass})" if cls.subclass.present? %>
          </span>
        <% end %>
        <span class="text-on-surface-variant font-medium text-lg italic"><%= @character.race %></span>
        <span class="text-on-surface-variant/60 font-medium"><%= @character.alignment %></span>
      </div>

      <% if @health %>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <span class="stat-label">HP</span>
          <span class="font-bold text-tertiary-container"><%= @health.current_hp %> / <%= @health.max_hp %></span>
          <% if @health.temporary_hp > 0 %>
            <span class="text-xs text-secondary">+<%= @health.temporary_hp %> temp</span>
          <% end %>
          <% @health.conditions.each do |cond| %>
            <span class="text-xs bg-error-container/60 text-error px-2 py-0.5 rounded"><%= cond %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

  <%# ── Left: Core Attributes & Combat Stats ─────────────────────────────── %>
  <div class="lg:col-span-4 space-y-8">

    <div class="glass-panel p-6 rounded-xl parchment-texture">
      <h3 class="section-header mb-6">
        <span class="material-symbols-outlined text-sm">auto_awesome</span>
        Core Attributes
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <% CharacterSheet::STATS.each do |stat| %>
          <div class="flex flex-col items-center bg-surface-container p-4 rounded-lg border border-outline-variant/10 hover:border-primary/30 transition-all group">
            <span class="text-[10px] uppercase font-bold tracking-tighter text-outline-variant mb-1 group-hover:text-primary/70 transition-colors">
              <%= @sheet.ability_abbreviation(stat) %>
            </span>
            <span class="text-3xl font-headline font-bold text-primary"><%= @sheet.stat_display(stat) %></span>
            <div class="mt-2 bg-surface-container-highest px-3 py-1 rounded-full text-sm font-bold text-on-surface">
              <%= @sheet.modifier_string(stat) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="bg-surface-container-low p-5 rounded-xl border border-outline-variant/10 text-center">
        <span class="stat-label block">Armor Class</span>
        <div class="text-4xl font-headline font-bold text-primary mt-2"><%= @sheet.armor_class.presence || "—" %></div>
      </div>
      <div class="bg-surface-container-low p-5 rounded-xl border border-outline-variant/10 text-center">
        <span class="stat-label block">Initiative</span>
        <div class="text-4xl font-headline font-bold text-primary mt-2"><%= @sheet.initiative_string %></div>
      </div>
      <div class="bg-surface-container-low p-5 rounded-xl border border-outline-variant/10 text-center">
        <span class="stat-label block">Speed</span>
        <div class="text-4xl font-headline font-bold text-primary mt-2">
          <%= @sheet.speed.presence || 30 %><span class="text-sm text-on-surface-variant ml-1">ft</span>
        </div>
      </div>
      <div class="bg-surface-container-low p-5 rounded-xl border border-outline-variant/10 text-center">
        <span class="stat-label block">Proficiency</span>
        <div class="text-4xl font-headline font-bold text-primary mt-2">+<%= @sheet.effective_proficiency_bonus %></div>
      </div>
    </div>

    <% if @health %>
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
        <div class="flex justify-between items-center mb-3">
          <span class="stat-label">Hit Points</span>
          <span class="text-primary font-bold"><%= @health.current_hp %> / <%= @health.max_hp %></span>
        </div>
        <div class="hp-bar">
          <div class="h-full bg-tertiary-container rounded-full transition-all"
               style="width: <%= @health.hp_percentage %>%"></div>
        </div>
        <div class="flex gap-2 mt-4">
          <button class="flex-1 py-1.5 text-xs font-bold bg-surface-container-highest rounded hover:bg-tertiary/20 transition-colors">HEAL</button>
          <button class="flex-1 py-1.5 text-xs font-bold bg-surface-container-highest rounded hover:bg-error/20 transition-colors">DAMAGE</button>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Middle: Skills & Saves ────────────────────────────────────────────── %>
  <div class="lg:col-span-4 glass-panel p-6 rounded-xl parchment-texture">
    <h3 class="section-header mb-6">
      <span class="material-symbols-outlined text-sm">military_tech</span>
      Proficiency &amp; Skills
    </h3>

    <div class="space-y-6">
      <div>
        <h4 class="text-[10px] uppercase font-bold text-on-surface-variant mb-3 border-b border-outline-variant/20 pb-1">Saving Throws</h4>
        <div class="space-y-2">
          <% CharacterSheet::STATS.each do |stat| %>
            <% proficient = @sheet.proficient_in_save?(stat) %>
            <div class="flex items-center justify-between text-sm group">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full border <%= proficient ? "border-primary bg-primary shadow-[0_0_6px_rgba(242,202,80,0.4)]" : "border-outline-variant" %>"></div>
                <span class="<%= proficient ? "group-hover:text-primary" : "opacity-60" %> transition-colors">
                  <%= stat.capitalize %>
                </span>
              </div>
              <span class="font-bold <%= proficient ? "" : "opacity-60" %>">
                <%= @sheet.saving_throw_modifier_string(stat) %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <div>
        <h4 class="text-[10px] uppercase font-bold text-on-surface-variant mb-3 border-b border-outline-variant/20 pb-1">Skills</h4>
        <div class="space-y-2 max-h-[320px] overflow-y-auto pr-1 custom-scrollbar">
          <% CharacterSheet::SKILLS.each_key do |skill| %>
            <% proficient = @sheet.proficient_in_skill?(skill) %>
            <% has_bonus  = @sheet.skill_bonus(skill).nonzero? %>
            <div class="flex items-center justify-between text-xs group">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full border <%= proficient ? "border-primary bg-primary" : "border-outline-variant" %>"></div>
                <span class="<%= proficient || has_bonus ? "group-hover:text-primary" : "opacity-60" %> transition-colors">
                  <%= @sheet.skill_display_name(skill) %> (<%= @sheet.skill_ability_abbr(skill) %>)
                </span>
              </div>
              <div class="flex items-center gap-1.5">
                <% if has_bonus %>
                  <span class="text-[9px] border <%= @sheet.skill_bonus(skill) > 0 ? "border-primary/30 text-primary" : "border-error/30 text-error" %> px-1 rounded">
                    <%= @sheet.skill_bonus(skill) > 0 ? "+#{@sheet.skill_bonus(skill)}" : @sheet.skill_bonus(skill) %>
                  </span>
                <% end %>
                <span class="font-bold <%= proficient || has_bonus ? "" : "opacity-60" %>">
                  <%= @sheet.skill_modifier_string(skill) %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-surface-container p-4 rounded-xl border border-outline-variant/10 text-center">
        <span class="material-symbols-outlined text-primary mb-1">visibility</span>
        <p class="text-xs font-bold text-on-surface">Passive Perception</p>
        <p class="text-3xl font-headline text-primary mt-1"><%= @sheet.passive_perception %></p>
      </div>
    </div>
  </div>

  <%# ── Right: Actions & Spells ──────────────────────────────────────────── %>
  <div class="lg:col-span-4 space-y-8">
    <% if @weapons.any? %>
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
        <h3 class="section-header mb-6">
          <span class="material-symbols-outlined text-sm">swords</span>
          Quick Actions
        </h3>
        <div class="space-y-3">
          <% @weapons.each do |weapon| %>
            <div class="bg-surface-container p-4 rounded-lg border border-outline-variant/10 flex items-center gap-4 hover:bg-surface-container-high transition-colors">
              <div class="w-10 h-10 flex items-center justify-center bg-primary/10 rounded-lg text-primary shrink-0">
                <span class="material-symbols-outlined">swords</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-on-surface truncate"><%= weapon.name %></p>
                <p class="text-[10px] text-on-surface-variant uppercase tracking-tighter truncate"><%= weapon.description&.truncate(40) %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @spells.any? %>
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
        <h3 class="mb-6 text-secondary font-headline text-lg uppercase tracking-widest flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">magic_button</span>
          Active Spells
        </h3>
        <div class="space-y-3">
          <% @spells.first(5).each do |spell| %>
            <div class="p-3 bg-secondary/5 border-l-2 border-secondary rounded-r-lg flex justify-between items-center group hover:bg-secondary/10 transition-colors">
              <div>
                <p class="text-sm font-bold text-on-surface"><%= spell.name %></p>
                <p class="text-[10px] text-secondary tracking-widest uppercase">
                  <%= spell.cantrip? ? "Cantrip" : "Level #{spell.spell_level}" %> <%= spell.school %>
                </p>
              </div>
              <span class="material-symbols-outlined text-sm opacity-30 group-hover:opacity-100 transition-opacity">bolt</span>
            </div>
          <% end %>
        </div>

        <% if @spell_slots.any? %>
          <div class="mt-6 pt-6 border-t border-outline-variant/10">
            <% @spell_slots.first(3).each do |slot| %>
              <div class="flex justify-between items-center mb-2">
                <span class="stat-label">Level <%= slot.slot_level %></span>
                <div class="flex gap-1">
                  <% slot.total.times do |i| %>
                    <div class="w-3 h-3 rounded-sm <%= i < slot.used ? "bg-outline-variant/30" : "bg-secondary shadow-[0_0_6px_rgba(223,183,255,0.4)]" %>"></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 space-y-3">
      <div class="flex justify-between items-center">
        <span class="stat-label">Experience Points</span>
        <span class="font-bold text-on-surface"><%= number_with_delimiter(@character.experience_points) %> XP</span>
      </div>
      <%= link_to character_inventory_items_path(@character),
            class: "btn-secondary w-full py-2.5 rounded-lg flex items-center justify-center gap-2 text-sm" do %>
        <span class="material-symbols-outlined text-sm">auto_stories</span>
        Inventory &amp; Spells
      <% end %>
      <div class="flex gap-2 pt-1">
        <%= link_to edit_character_sheet_path(@character),
              class: "flex-1 flex items-center justify-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors" do %>
          <span class="material-symbols-outlined text-xs">tune</span>
          Edit Stats
        <% end %>
        <%= link_to edit_character_path(@character),
              class: "flex-1 flex items-center justify-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors" do %>
          <span class="material-symbols-outlined text-xs">edit</span>
          Edit Character
        <% end %>
      </div>
    </div>
  </div>
</div>

<button class="fixed bottom-8 right-8 w-16 h-16 bg-primary text-on-primary rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50"
        title="Roll Dice">
  <span class="material-symbols-outlined text-3xl">casino</span>
</button>
