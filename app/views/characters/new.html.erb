<%= content_for :title, "New Character — The Chronicler" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <% if Current.campaign %>
      <p class="text-xs text-primary font-bold uppercase tracking-widest mb-1"><%= Current.campaign.name %></p>
    <% end %>
    <h1 class="font-headline text-4xl font-bold text-on-surface tracking-tight mb-2">Create Character</h1>
    <p class="text-on-surface-variant">Forge your legend. You can fill in stats and backstory from the character sheet.</p>
  </div>

  <%= render "form", character: @character %>
</div>
