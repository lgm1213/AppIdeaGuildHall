<%# locals: (character:) %>
<div class="bg-surface-container-low border border-outline-variant/10 rounded-xl p-8 shadow-xl">
  <%= form_with model: character, class: "space-y-6" do |f| %>
    <% if character.errors.any? %>
      <div class="bg-error-container border border-error/30 text-on-error-container rounded-lg p-4 text-sm">
        <span class="material-symbols-outlined text-sm align-middle mr-1">warning</span>
        <%= character.errors.full_messages.first %>
      </div>
    <% end %>

    <%# Preserve campaign context for new characters %>
    <% unless character.persisted? %>
      <%= hidden_field_tag :campaign_id, Current.campaign&.id %>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="md:col-span-2">
        <label class="stat-label block mb-2">Character Name</label>
        <%= f.text_field :name,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "Thorin Ironforge",
              autofocus: true %>
      </div>

      <div>
        <label class="stat-label block mb-2">Race</label>
        <%= f.text_field :race,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "Dwarf, Human, Elf…" %>
      </div>

      <div>
        <label class="stat-label block mb-2">Alignment</label>
        <%= f.text_field :alignment,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface placeholder-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all",
              placeholder: "Lawful Good" %>
      </div>

      <div>
        <label class="stat-label block mb-2">Experience Points</label>
        <%= f.number_field :experience_points,
              min: 0,
              class: "w-full bg-surface-container border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" %>
      </div>

      <div>
        <label class="stat-label block mb-2">Avatar <span class="text-outline normal-case font-normal">(optional)</span></label>
        <%= f.file_field :avatar,
              accept: "image/*",
              class: "w-full text-sm text-on-surface-variant file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-surface-container-highest file:text-on-surface hover:file:bg-surface-container-high transition-all" %>
      </div>
    </div>

    <div class="flex gap-4 pt-2">
      <%= f.submit character.persisted? ? "Save Changes" : "Create Character",
            class: "btn-primary px-8 py-3 rounded-lg cursor-pointer" %>
      <% if character.persisted? %>
        <%= link_to "Cancel", character_sheet_path(character),
              class: "btn-secondary px-8 py-3 rounded-lg" %>
      <% else %>
        <%= link_to "Cancel", Current.campaign ? campaign_path(Current.campaign) : campaigns_path,
              class: "btn-secondary px-8 py-3 rounded-lg" %>
      <% end %>
    </div>
  <% end %>
</div>
